{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.mjs",
    "lint:ci": "eslint . --ext .ts,.tsx,.js,.jsx,.mjs --max-warnings=0 && prettier --check .",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx,.mjs --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "echo 'Type checking disabled for docs'"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,mdx,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@takumi-rs/image-response": "^0.69.5",
    "fumadocs-core": "16.6.9",
    "fumadocs-mdx": "14.2.9",
    "fumadocs-ui": "16.6.9",
    "lucide-react": "^0.575.0",
    "next": "16.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.4.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.10",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
