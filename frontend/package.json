{
    "name": "viernulvier-archief",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev --turbo",
        "build": "next build",
        "start": "next start",
        "generate:api-types": "node ./scripts/generate-openapi-types.mjs",
        "test": "NODE_NO_WARNINGS=1 vitest",
        "test:run": "NODE_NO_WARNINGS=1 vitest run",
        "test:coverage": "NODE_NO_WARNINGS=1 vitest run --coverage",
        "lint": "eslint . --ext js,ts,tsx --cache",
        "lint:fix": "eslint . --ext js,ts,tsx --fix --cache && npx prettier --write .",
        "lint:ci": "eslint . --ext js,ts,tsx --max-warnings=0 && npx prettier --check .",
        "knip": "knip",
        "typecheck": "tsc --noEmit",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx}": [
            "./node_modules/.bin/eslint --fix",
            "./node_modules/.bin/prettier --write"
        ],
        "*.{css,md,json}": [
            "./node_modules/.bin/prettier --write"
        ]
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@next/bundle-analyzer": "^16.1.6",
        "@swc/helpers": "0.5.21",
        "@t3-oss/env-nextjs": "^0.13.10",
        "@t3-oss/env-nuxt": "^0.13.10",
        "@tailwindcss/typography": "^0.5.19",
        "@tanstack/react-query": "^5.90.21",
        "@tanstack/react-query-devtools": "^5.91.3",
        "@tanstack/react-table": "^8.21.3",
        "@tiptap/core": "^3.21.0",
        "@tiptap/extension-image": "^3.22.3",
        "@tiptap/extension-link": "^3.21.0",
        "@tiptap/extension-placeholder": "^3.21.0",
        "@tiptap/pm": "^3.21.0",
        "@tiptap/react": "^3.21.0",
        "@tiptap/starter-kit": "^3.21.0",
        "animejs": "^4.3.6",
        "axios": "^1.15.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^0.575.0",
        "next": "16.2.3",
        "next-intl": "^4.8.3",
        "next-themes": "^0.4.6",
        "radix-ui": "^1.4.3",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "webpack": "^5.105.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@codecov/webpack-plugin": "^1.9.1",
        "@eslint/eslintrc": "^0.1.0",
        "@playwright/test": "^1.58.2",
        "@tailwindcss/postcss": "^4",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/animejs": "^3.1.13",
        "@types/node": "^20.19.33",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitest/coverage-v8": "^4.1.0",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^9.39.3",
        "eslint-config-next": "^16.1.6",
        "jsdom": "^29.0.1",
        "knip": "^5.85.0",
        "msw": "^2.12.14",
        "openapi-typescript": "^7.10.1",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "shadcn": "^3.8.5",
        "tailwindcss": "^4",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.9.3",
        "vitest": "^4.1.0"
    }
}
